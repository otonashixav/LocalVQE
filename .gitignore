# C++ build
ggml/build/
ggml/build-*/

# Emscripten / WASM
.em-cache/
a.out.js
a.out.wasm
a.out.wat
web/vendor/localvqe.js
web/vendor/localvqe.wasm
web/browser_test.png

# Python
__pycache__/
*.pyc
.venv/
*.egg-info/

# Model weights (download from Hugging Face)
*.gguf
*.pt
*.bin

# Test fixtures live under tests/ — keep them tracked despite the
# weight-binary patterns above.
!pytorch/tests/fixtures/*.pt
!ggml/tests/fixtures/*.f32
# GTCRN-AEC parity reference (small ~2.3 MB GGUF + .npy stage dumps) so
# `test_gtcrn --fixtures` runs self-contained from a clean clone.
!ggml/tests/gtcrn/*.gguf

# Generated audio
*.wav

# Editors / tools
.direnv/
.claude/
.cache/

# Local benchmark / scratch output
bench_results/
